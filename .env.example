# OpenAI API Key (Optional)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key for Instant Chatbot Responses (Optional, recommended for speed)
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant Vector Database configurations
QDRANT_URL=your_qdrant_cloud_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=portfolio

# Local Ollama Inference Configuration (used if GEMINI_API_KEY is not set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

